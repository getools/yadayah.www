RewriteEngine On

# ── Ban check: block temporarily banned IPs ──
php_value auto_prepend_file "/var/www/html/api/check-ban.php"

# ── Honeypot: trap known attack paths and ban the IP ──
RewriteRule ^(wp-config|wp-login|wp-admin|wp-includes|xmlrpc|wp-content|wordpress) /api/honeypot.php [L,NC]
RewriteRule \.(ashx|aspx|asp|cgi|env|bak|sql|orig|save|old|swp|dist|config)$ /api/honeypot.php [L,NC]
RewriteRule (phpmyadmin|myadmin|mysql|adminer|phpinfo|eval-stdin|vendor/phpunit|solr|actuator|telescope) /api/honeypot.php [L,NC]
RewriteRule (\.git/|\.svn/|\.env|\.DS_Store|\.htpasswd|/config\.php\.|/db\.php\.) /api/honeypot.php [L,NC]

# Legacy PDF URLs → canonical hyphenated names (301). One rule per file —
# matches against the decoded URI (Apache decodes %20 to real space before
# rule evaluation), so the LHS uses spaces and the RHS uses hyphens. Only
# the historically-spaced PDFs are listed; unrelated /pdf/* URLs fall
# through normally.
#
# Mark the response uncacheable for any /pdf/ URL containing a literal
# space (i.e. came in as %20). Otherwise Cloudflare can pin a stale 200-OK
# or a stale 301 mapping for hours, defeating new redirects after a rename.
<IfModule mod_headers.c>
    SetEnvIf Request_URI " " PDF_HAS_SPACE=1
    Header always set Cache-Control "no-store, must-revalidate" env=PDF_HAS_SPACE
</IfModule>
RewriteRule "^pdf/YY-s01v01-An Intro to God-Dabarym-Words\.pdf$"           "/pdf/YY-s01v01-An-Intro-to-God-Dabarym-Words.pdf"           [R=301,L]
RewriteRule "^pdf/YY-s01v02-An Intro to God-Mitswah-Instructions\.pdf$"    "/pdf/YY-s01v02-An-Intro-to-God-Mitswah-Instructions.pdf"    [R=301,L]
RewriteRule "^pdf/YY-s01v03-An Intro to God-Towrah Mizmowr\.pdf$"          "/pdf/YY-s01v03-An-Intro-to-God-Towrah-Mizmowr.pdf"          [R=301,L]
RewriteRule "^pdf/YY-s02v01-Yada Yahowah-Bare'syth-Beginning\.pdf$"        "/pdf/YY-s02v01-Yada-Yahowah-Bare'syth-Beginning.pdf"        [R=301,L]
RewriteRule "^pdf/YY-s02v02-Yada Yahowah-'Adam-The Story of Man\.pdf$"     "/pdf/YY-s02v02-Yada-Yahowah-'Adam-The-Story-of-Man.pdf"     [R=301,L]
RewriteRule "^pdf/YY-s02v03-Yada Yahowah-Beyth-In the Family\.pdf$"        "/pdf/YY-s02v03-Yada-Yahowah-Beyth-In-the-Family.pdf"        [R=301,L]
RewriteRule "^pdf/YY-s02v04-Yada Yahowah-Miqra'ey-Invitations\.pdf$"       "/pdf/YY-s02v04-Yada-Yahowah-Miqra'ey-Invitations.pdf"       [R=301,L]
RewriteRule "^pdf/YY-s02v05-Yada Yahowah-Qatsyr-Harvests\.pdf$"            "/pdf/YY-s02v05-Yada-Yahowah-Qatsyr-Harvests.pdf"            [R=301,L]
RewriteRule "^pdf/YY-s02v06-Yada Yahowah-Mow'ed-Appointments\.pdf$"        "/pdf/YY-s02v06-Yada-Yahowah-Mow'ed-Appointments.pdf"        [R=301,L]
RewriteRule "^pdf/YY-s02v07-Yada Yahowah-Shanah-Years\.pdf$"               "/pdf/YY-s02v07-Yada-Yahowah-Shanah-Years.pdf"               [R=301,L]
RewriteRule "^pdf/YY-s02v08-Yada Yahowah-'Azab-Separation\.pdf$"           "/pdf/YY-s02v08-Yada-Yahowah-'Azab-Separation.pdf"           [R=301,L]
RewriteRule "^pdf/YY-s02v09-Yada Yahowah-'Eth Tsarah-Time of Trouble\.pdf$" "/pdf/YY-s02v09-Yada-Yahowah-'Eth-Tsarah-Time-of-Trouble.pdf" [R=301,L]
RewriteRule "^pdf/YY-s04v01-Coming Home-Qowl-A Voice\.pdf$"                "/pdf/YY-s04v01-Coming-Home-Qowl-A-Voice.pdf"                [R=301,L]
RewriteRule "^pdf/YY-s04v02-Coming Home-Mashyach-Messiah\.pdf$"            "/pdf/YY-s04v02-Coming-Home-Mashyach-Messiah.pdf"            [R=301,L]
RewriteRule "^pdf/YY-s04v03-Coming Home-Dowd-Beloved\.pdf$"                "/pdf/YY-s04v03-Coming-Home-Dowd-Beloved.pdf"                [R=301,L]
RewriteRule "^pdf/YY-s04v04-Coming Home-Basar-Herald\.pdf$"                "/pdf/YY-s04v04-Coming-Home-Basar-Herald.pdf"                [R=301,L]
RewriteRule "^pdf/YY-s06v03-Twistianity-Devils Advocate\.pdf$"             "/pdf/YY-s06v03-Twistianity-Devils-Advocate.pdf"             [R=301,L]
RewriteRule "^pdf/YY-s07v01-God Damn Religion-Snake\.pdf$"                 "/pdf/YY-s07v01-God-Damn-Religion-Snake.pdf"                 [R=301,L]
RewriteRule "^pdf/YY-s07v02-God Damn Religion-Satanic\.pdf$"               "/pdf/YY-s07v02-God-Damn-Religion-Satanic.pdf"               [R=301,L]
RewriteRule "^pdf/YY-s07v03-God Damn Religion-Submission\.pdf$"            "/pdf/YY-s07v03-God-Damn-Religion-Submission.pdf"            [R=301,L]
RewriteRule "^pdf/YY-s07v04-God Damn Religion-Slaughter\.pdf$"             "/pdf/YY-s07v04-God-Damn-Religion-Slaughter.pdf"             [R=301,L]
RewriteRule "^pdf/YY-s07v05-God Damn Religion-Sunnah and Suratun\.pdf$"    "/pdf/YY-s07v05-God-Damn-Religion-Sunnah-and-Suratun.pdf"    [R=301,L]
RewriteRule "^pdf/In the Company of Good and Evil\.pdf$"                   "/pdf/In-the-Company-of-Good-and-Evil.pdf"                   [R=301,L]

# Strip trailing slashes (301 redirect to canonical URL without slash)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Redirect old .html URLs to clean paths (301 permanent)
RewriteCond %{THE_REQUEST} \s/+(books|vlog|ask|timeline|glossary|dss|search|Craig_Winn|resources|invite|blog|music|media|translations|chat|admin|admin-[a-z]+|10-7-memorial)\.html[\s?] [NC]
RewriteRule ^(books|vlog|ask|timeline|glossary|dss|search|Craig_Winn|resources|invite|blog|music|media|translations|chat|admin|admin-[a-z]+|10-7-memorial)\.html$ /$1 [R=301,L]

# Memorial: /memorial → /10-7-memorial, /memorial/Name → /10-7-memorial/Name
RewriteRule ^memorial/(.+)$ /10-7-memorial.html?name=$1 [L,QSA]
RewriteRule ^memorial$ /10-7-memorial [R=301,L]

# Memorial deep-link: /10-7-memorial/Name → 10-7-memorial.html?name=Name
RewriteRule ^10-7-memorial/(.+)$ /10-7-memorial.html?name=$1 [L,QSA]

# Redirect /time to /timeline
RewriteRule ^time$ /timeline [R=301,L,NC]

# Redirect /community to /chat
RewriteRule ^community$ /chat [R=301,L,NC]

# Canonical redirect for Craig_Winn (mixed case filename)
RewriteCond %{REQUEST_URI} !^/Craig_Winn$
RewriteRule ^craig_winn$ /Craig_Winn [R=301,L,NC]

# Canonical redirect for DoYouYada (mixed case filename)
RewriteCond %{REQUEST_URI} !^/DoYouYada$
RewriteRule ^doyouyada$ /DoYouYada [R=301,L,NC]

# Case-insensitive URL matching: try lowercase .html file
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} [A-Z]
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/Craig_Winn$ [NC]
RewriteCond %{REQUEST_URI} !^/DoYouYada$ [NC]
RewriteRule ^(.+)$ /case-redirect.php [L,QSA]

# Serve clean URLs from .html files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Route API requests to the api directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/(.*)$ /api/$1 [L]

# All other unmatched requests: check redirects table, then 404
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/api/
RewriteRule ^(.+)$ /case-redirect.php [L,QSA]
